@page
@model IndexModel

<div class="container dashboard @(Model.DashboardKind == "New" ? "dashboard-new" : "dashboard-classic")">
    <div class="dashboard-header">
        <h2>Dashboard</h2>
        <span class="dashboard-kind">@Model.DashboardKind</span>
    </div>
    <p class="dashboard-subtitle">Mode selected by API feature flag <strong>NewDashboard</strong>.</p>

    @if (Model.DashboardKind == "New")
    {
        <section class="dashboard-grid">
            <article class="panel panel-hero">
                <h3>New Dashboard</h3>
                <p>Modern layout with prioritized insights and recent activity.</p>
            </article>
            <article class="panel">
                <h4>Live Overview</h4>
                <p>Traffic and system trends in real time.</p>
            </article>
            <article class="panel">
                <h4>Activity Feed</h4>
                <p>Recent app events and status updates.</p>
            </article>
            <article class="panel">
                <h4>Insights</h4>
                <p>Suggested actions based on current usage signals.</p>
            </article>
        </section>
    }
    else
    {
        <section class="dashboard-stack">
            <article class="panel panel-hero">
                <h3>Classic Dashboard</h3>
                <p>Familiar card stack for simple review and quick checks.</p>
            </article>
            <article class="panel">
                <h4>Summary Widgets</h4>
                <p>Core totals and key status indicators.</p>
            </article>
            <article class="panel">
                <h4>Recent Updates</h4>
                <p>Latest changes with timestamps.</p>
            </article>
            <article class="panel">
                <h4>Basic Metrics</h4>
                <p>Requests, uptime, and response health.</p>
            </article>
        </section>
    }

    <p class="source">Source: @Model.ApiBaseUrl/api/dashboard-mode</p>

    <section class="panel key-check-panel">
        <h3>MY_API_KEY Verification</h3>
        <p>Compares UI and API diagnostics without exposing the full key.</p>
        <div class="key-check-grid">
            <div>
                <h4>UI</h4>
                <p>Has value: <strong>@Model.UiKeyHasValue</strong></p>
                <p>Length: <strong>@Model.UiKeyLength</strong></p>
                <p>Preview: <strong>@Model.UiKeyPreview</strong></p>
                <p>Fingerprint: <strong>@Model.UiKeyFingerprint</strong></p>
            </div>
            <div>
                <h4>API</h4>
                <p>Has value: <strong>@Model.ApiKeyHasValue</strong></p>
                <p>Length: <strong>@Model.ApiKeyLength</strong></p>
                <p>Preview: <strong>@Model.ApiKeyPreview</strong></p>
                <p>Fingerprint: <strong>@Model.ApiKeyFingerprint</strong></p>
            </div>
        </div>
        <p class="key-check-result @(Model.KeyFingerprintMatch ? "match" : "mismatch")">
            Fingerprint match: <strong>@Model.KeyFingerprintMatch</strong>
        </p>
    </section>
</div>
