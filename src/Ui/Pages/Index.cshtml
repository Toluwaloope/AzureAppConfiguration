@page
@model IndexModel

<div class="container">
    <h2>Dashboard</h2>
    <p>Mode selected by API feature flag <strong>NewDashboard</strong>: <strong>@Model.DashboardKind</strong></p>

    @if (Model.DashboardKind == "New")
    {
        <section>
            <h3>New Dashboard</h3>
            <ul>
                <li>Live Overview</li>
                <li>Modern Activity Feed</li>
                <li>Advanced Insights Panel</li>
            </ul>
        </section>
    }
    else
    {
        <section>
            <h3>Classic Dashboard</h3>
            <ul>
                <li>Summary Widgets</li>
                <li>Recent Updates</li>
                <li>Basic Metrics</li>
            </ul>
        </section>
    }

    <p style="margin-top:1rem;color:#666;">Source: @Model.ApiBaseUrl/api/dashboard-mode</p>
</div>
