@page
@model IndexModel

<div class="container dashboard @(Model.DashboardKind == "New" ? "dashboard-new" : "dashboard-classic")">
    <div class="dashboard-header">
        <h2>Dashboard</h2>
        <span class="dashboard-kind">@Model.DashboardKind</span>
    </div>
    <p class="dashboard-subtitle">Mode selected by API feature flag <strong>NewDashboard</strong>.</p>

    @if (Model.DashboardKind == "New")
    {
        <section class="dashboard-grid">
            <article class="panel panel-hero">
                <h3>New Dashboard</h3>
                <p>Modern layout with prioritized insights and recent activity.</p>
            </article>
            <article class="panel">
                <h4>Live Overview</h4>
                <p>Traffic and system trends in real time.</p>
            </article>
            <article class="panel">
                <h4>Activity Feed</h4>
                <p>Recent app events and status updates.</p>
            </article>
            <article class="panel">
                <h4>Insights</h4>
                <p>Suggested actions based on current usage signals.</p>
            </article>
        </section>
    }
    else
    {
        <section class="dashboard-stack">
            <article class="panel panel-hero">
                <h3>Classic Dashboard</h3>
                <p>Familiar card stack for simple review and quick checks.</p>
            </article>
            <article class="panel">
                <h4>Summary Widgets</h4>
                <p>Core totals and key status indicators.</p>
            </article>
            <article class="panel">
                <h4>Recent Updates</h4>
                <p>Latest changes with timestamps.</p>
            </article>
            <article class="panel">
                <h4>Basic Metrics</h4>
                <p>Requests, uptime, and response health.</p>
            </article>
        </section>
    }

    <p class="source">Source: @Model.ApiBaseUrl/api/dashboard-mode</p>

    <section class="panel feature-list-panel">
        <h3>Available Features</h3>
        <p>Loaded from <strong>@Model.ApiBaseUrl/api/features</strong>.</p>
        @if (Model.AvailableFeatures.Any())
        {
            <ul class="feature-list">
                @foreach (var feature in Model.AvailableFeatures.OrderBy(f => f.Key))
                {
                    <li>
                        <span>@feature.Key</span>
                        <span class="feature-state @(feature.Value ? "enabled" : "disabled")">
                            @(feature.Value ? "Enabled" : "Disabled")
                        </span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No features were returned from the API.</p>
        }
    </section>
</div>
